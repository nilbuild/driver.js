---
import Sidebar from "../components/Sidebar.astro";
import Stage from "../components/Stage.astro";

interface Props {
  title?: string;
  description?: string;
  activeId?: string;
}

const { title, description, activeId } = Astro.props;
const pageTitle = title ? `${title} · driver.js playground` : "driver.js playground";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="layout">
      <Sidebar activeId={activeId} />
      <main class="content">
        {
          title && (
            <div class="example-heading">
              <h1>{title}</h1>
              {description && <p>{description}</p>}
            </div>
          )
        }
        <slot />
        <Stage />
      </main>
    </div>

    <style is:global>
      :root {
        --border: #e5e7eb;
        --muted: #6b7280;
        --accent: #2563eb;
        --bg: #ffffff;
        --sidebar-bg: #f9fafb;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans",
          "Helvetica Neue", sans-serif;
        font-size: 14px;
        color: #111827;
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      *:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        min-height: 100vh;
      }

      /* Sidebar */
      .sidebar {
        position: sticky;
        top: 0;
        align-self: start;
        height: 100vh;
        overflow-y: auto;
        padding: 20px;
        border-right: 1px solid var(--border);
        background: var(--sidebar-bg);
      }

      .sidebar-brand {
        display: block;
        margin-bottom: 20px;
        font-size: 18px;
        font-weight: 600;
        color: #111827;
        text-decoration: none;
      }

      .sidebar-brand span {
        color: var(--muted);
        font-weight: 400;
      }

      .sidebar-group {
        margin-bottom: 22px;
      }

      .sidebar-group h2 {
        margin: 0 0 8px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
      }

      .sidebar-group ul {
        list-style: none;
      }

      .sidebar-group li a {
        display: block;
        padding: 5px 10px;
        border-radius: 6px;
        color: #374151;
        text-decoration: none;
      }

      .sidebar-group li a:hover {
        background: #eef2ff;
        color: var(--accent);
      }

      .sidebar-group li a.is-active {
        background: var(--accent);
        color: #fff;
      }

      /* Content */
      .content {
        padding: 40px;
      }

      .example-heading {
        max-width: 640px;
        margin: 0 auto 10px;
      }

      .example-heading h1 {
        font-size: 24px;
        font-weight: 600;
      }

      .example-heading p {
        margin-top: 6px;
        color: var(--muted);
      }

      /* Demo stage */
      .demo-container {
        display: flex;
        flex-direction: column;
        max-width: 640px;
        margin: 0 auto;
        text-align: left;
      }

      .page-header {
        text-align: center;
        margin-bottom: 10px;
      }

      .demo-container p {
        line-height: 1.5;
        margin-bottom: 15px;
      }

      .demo-container h1,
      .demo-container h2 {
        margin: 30px 0 10px;
      }

      .demo-container h1 {
        font-size: 48px;
        font-weight: 600;
        text-align: center;
      }

      .demo-container h1 sup {
        font-size: 18px;
        font-weight: 400;
      }

      .feature-list,
      #hooks-list {
        list-style: none;
        padding: 0;
        margin: 20px 10px 0;
        line-height: 1.5;
      }

      .feature-list li:before,
      #hooks-list li:before {
        content: "•";
        margin-right: 10px;
      }

      .buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .demo-container button {
        all: unset;
        border: 1px solid #ccc;
        padding: 5px 15px;
        border-radius: 5px;
        cursor: pointer;
      }

      #scrollable-area {
        height: 300px;
        overflow: auto;
        border: 1px solid #ccc;
        padding: 10px;
        border-radius: 5px;
        margin: 50px 0;
      }

      /* Custom popover theme used by the "Custom Classes" example */
      .driver-popover.custom-driver-popover {
        min-width: 450px;
        background: #2d2d2d;
        color: white;
      }

      .driver-popover.custom-driver-popover .driver-popover-title {
        font-size: 26px;
      }

      .driver-popover.custom-driver-popover .driver-popover-description {
        font-size: 14px;
      }

      .driver-popover.custom-driver-popover button {
        background: #454545;
        border-color: #454545;
        text-shadow: none;
        color: white;
        font-size: 13px;
        padding: 7px 10px;
      }

      .driver-popover.custom-driver-popover button:hover {
        background: #575757;
      }

      .gif-popover {
        display: flex;
        flex-direction: column;
        text-align: center;
      }

      .gif-popover img {
        width: 100%;
        height: auto;
        margin-bottom: 10px;
      }

      .gif-popover p {
        margin-bottom: 0;
      }
    </style>
  </body>
</html>
