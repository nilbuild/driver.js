// The shared demo content every example highlights against. Examples reference
// these elements by selector, so keep ids/classes stable when editing.
---

<div class="demo-container">
  <header class="page-header">
    <h1>driver.js <sup>v1</sup></h1>
    <p>A lightweight, no-dependency library to drive the user's focus across the page.</p>
  </header>

  <h2>Highlight any element</h2>
  <p id="large-paragraph-text">
    Highlight anything, anywhere on the page — literally anything, including SVG portions, scrollable items and
    off-screen elements. Pick an example from the sidebar to see it in action.
  </p>

  <div class="buttons">
    <button id="card-1" type="button">Card One</button>
    <button id="card-2" type="button">Card Two</button>
    <button id="card-3" type="button">Card Three</button>
    <button id="card-4" type="button">Card Four</button>
    <button id="card-5" type="button">Card Five</button>
    <button id="card-6" type="button">Card Six</button>
  </div>

  <ul class="feature-list">
    <li>Written in TypeScript</li>
    <li>Lightweight — only ~5kb gzipped</li>
    <li>No dependencies</li>
    <li>MIT Licensed</li>
  </ul>

  <ul id="hooks-list">
    <li>Open the console to follow the hooks fired by an example.</li>
  </ul>

